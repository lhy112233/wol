{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "dev",
      "displayName": "Development",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/dev",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "WOL_BUILD_TESTS": "ON",
        "WOL_STATIC_LINK": "OFF"
      }
    },
    {
      "name": "release-static",
      "displayName": "Release Static",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release-static",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "WOL_BUILD_TESTS": "ON",
        "WOL_STATIC_LINK": "ON"
      }
    },
    {
      "name": "package",
      "displayName": "Package",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/package",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "WOL_BUILD_TESTS": "ON",
        "WOL_STATIC_LINK": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev",
      "configurePreset": "dev"
    },
    {
      "name": "release-static",
      "configurePreset": "release-static"
    },
    {
      "name": "package",
      "configurePreset": "package",
      "targets": ["package_wol"]
    }
  ],
  "testPresets": [
    {
      "name": "dev",
      "configurePreset": "dev",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release-static",
      "configurePreset": "release-static",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
